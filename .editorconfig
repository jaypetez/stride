# EditorConfig — https://editorconfig.org
# Matches the Biome formatting config (biome.json): 2-space indent, LF, trimmed.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown uses trailing spaces for hard line breaks.
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
