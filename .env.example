# Stride configuration — copy to .env and fill in. NEVER commit .env.
# Stride is local-first and single-user: you bring your own credentials.

# --- Strava (create your own app at https://www.strava.com/settings/api) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Loopback redirect used by the local OAuth flow (`stride connect`).
STRAVA_REDIRECT_URI=http://localhost:8721/callback
# Read-only scopes. Do not add activity:write.
STRAVA_SCOPES=read,activity:read_all,profile:read_all
# Parameterized API host (Strava migrates to api-v3.strava.com on 2027-01-04).
STRAVA_API_BASE=https://www.strava.com/api/v3

# --- Anthropic (bring your own key: https://console.anthropic.com/) ---
ANTHROPIC_API_KEY=
# Optional model overrides (defaults are sensible).
STRIDE_MODEL_PLAN=claude-opus-4-8
STRIDE_MODEL_CHAT=claude-sonnet-5
STRIDE_MODEL_CLASSIFY=claude-haiku-4-5

# --- Local storage ---
# Directory for the local data store and OAuth token file (kept 0600).
STRIDE_DATA_DIR=.stride

# --- API / web (only needed for M2/M3) ---
STRIDE_API_PORT=8720
