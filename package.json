{
  "name": "stride",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Your Strava agentic coach — a local-first, open-source AI running coach.",
  "license": "Apache-2.0",
  "author": "Jayson Petersen and Stride contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaypetez/stride.git"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo watch test",
    "test:affected": "turbo run test --filter=...[origin/main]",
    "coverage": "turbo run test -- --coverage",
    "lint": "biome check .",
    "format": "biome check --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify",
    "verify": "node scripts/smoke.mjs",
    "dev": "turbo run dev",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
